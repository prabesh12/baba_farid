# Google Business Profile Reviews API
# These credentials are required to fetch real Google reviews
# Leave these commented out to use mock reviews during development

# Get your Business Account ID from Google Business Profile
# GOOGLE_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID

# Get your API Key from Google Cloud Console
# Steps:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project or select existing one
# 3. Enable "Business Profile API" and "Places API"
# 4. Create a Service Account and get the API key
# 5. Add the API key below
# GOOGLE_PLACES_API_KEY=YOUR_API_KEY
